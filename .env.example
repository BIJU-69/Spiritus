# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Admin panel password (change this before deploying!)
ADMIN_PASSWORD=spiritus2026

# Your deployed site URL (no trailing slash)
BASE_URL=https://spiritus.onrender.com

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex())")
SECRET_KEY=change-me-to-a-long-random-string

# Database URL (default: SQLite. For Supabase PostgreSQL, replace with postgres://... URL)
DATABASE_URL=sqlite:///alcohol.db
